# ── Prod environment — copy to .env.prod and fill in real values ──────────────
# DB URLs are injected by docker-compose — do NOT set them here.

# Auth — MUST be a strong random key in production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-STRONG-RANDOM-KEY-32-CHARS-MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — set to your actual domain in prod
CORS_ORIGINS=["http://localhost"]

# App
ENVIRONMENT=production
DEBUG=false
PAPER_CAPITAL=100000.0

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Broker — Zerodha Kite Connect (optional — needed for Live Trading and MCX)
# Get these from https://developers.kite.trade/apps
# KITE_API_KEY=xxxxxxxxxxxxxxxx
# KITE_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Observability (optional — error tracking no-ops if unset)
# Create a free project at sentry.io and paste its DSN here.
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz

# Observability — recommended once Alertmanager is running (see
# infra/monitoring/alertmanager). Without this, the alert webhook
# receiver accepts unauthenticated requests since nginx proxies all of
# /api/ publicly. Generate: python -c "import secrets; print(secrets.token_hex(24))"
# ALERTMANAGER_WEBHOOK_SECRET=CHANGE-ME-RANDOM-SECRET

# Email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# REPORT_TO_EMAIL=your@gmail.com

# Postgres — override defaults set in docker-compose if needed
# POSTGRES_USER=mts
# POSTGRES_PASSWORD=CHANGE-ME-STRONG-PASSWORD
# POSTGRES_DB=mts_prod
