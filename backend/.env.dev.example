# ── Dev environment — copy to .env.dev and fill in values ────────────────────
# DB URLs are injected by docker-compose (they use docker service names).
# Only set app-level config here.

# Auth — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — allow the local Next.js dev server
CORS_ORIGINS=["http://localhost:3000"]

# App
ENVIRONMENT=development
DEBUG=true
PAPER_CAPITAL=100000.0

# AI (optional — rule-based engine used if not set)
# ANTHROPIC_API_KEY=sk-ant-...

# Broker — Zerodha Kite Connect (optional — needed for Live Trading and MCX)
# Get these from https://developers.kite.trade/apps
# KITE_API_KEY=xxxxxxxxxxxxxxxx
# KITE_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Broker — Upstox (optional)
# Get these from https://developer.upstox.com/apps
# UPSTOX_API_KEY=xxxxxxxxxxxxxxxx
# UPSTOX_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# UPSTOX_REDIRECT_URI=http://localhost:3000/broker/upstox/callback

# Broker — Alice Blue / ANT (optional)
# Get these from https://v2api.aliceblueonline.com (register an app)
# ALICEBLUE_APP_CODE=xxxxxxxxxxxxxxxx
# ALICEBLUE_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALICEBLUE_REDIRECT_URI=http://localhost:3000/broker/aliceblue/callback

# Broker — Dhan: no keys here. Each user pastes their own client ID +
# access token (generated at web.dhan.co → My Profile → Access DhanHQ APIs)
# directly on the Broker page.

# Observability (optional — error tracking no-ops if unset)
# Create a free project at sentry.io and paste its DSN here.
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz

# Observability — shared secret for the Alertmanager webhook receiver (optional in dev)
# ALERTMANAGER_WEBHOOK_SECRET=dev-webhook-secret-change-me

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# REPORT_TO_EMAIL=your@gmail.com
