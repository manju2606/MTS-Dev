# ── Database ─────────────────────────────────────────────────────────────────
# Async URL for the app (asyncpg); Alembic uses a separate sync URL (psycopg2)
DATABASE_URL=postgresql+asyncpg://mts:mts_password@localhost:5435/mts_dev

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6381

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27018
MONGODB_DB=mts_journal

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
PAPER_CAPITAL=100000.0

# ── AI (optional) ────────────────────────────────────────────────────────────
# If not set, the rule-based local engine is used instead of Claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── Email — Daily Research Report ────────────────────────────────────────────
# Option A: Gmail SMTP (recommended for personal use)
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password (select "Mail" + "Other")
#   4. Paste the 16-char password below — do NOT use your regular Google password
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password
# SMTP_FROM=your@gmail.com

# Option B: Resend API (alternative — set RESEND_API_KEY instead of SMTP_*)
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@yourdomain.com

# Recipient for the 08:00 IST daily picks email (defaults to SMTP_USER if unset)
# REPORT_TO_EMAIL=manju2606@gmail.com

# ── Broker — Zerodha Kite Connect (Phase 3) ──────────────────────────────────
# KITE_API_KEY=
# KITE_API_SECRET=
