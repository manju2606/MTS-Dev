# ── Database ─────────────────────────────────────────────────────────────────
# Async URL for the app (asyncpg); Alembic uses a separate sync URL (psycopg2)
DATABASE_URL=postgresql+asyncpg://mts:mts_password@localhost:5435/mts_dev

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6381

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27018
MONGODB_DB=mts_journal

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
PAPER_CAPITAL=100000.0

# ── AI (optional) ────────────────────────────────────────────────────────────
# If not set, the rule-based local engine is used instead of Claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── Email (optional) ─────────────────────────────────────────────────────────
# If not set, password-reset tokens are logged to stdout instead of emailed
# RESEND_API_KEY=re_...

# ── Broker — Zerodha Kite Connect (Phase 3) ──────────────────────────────────
# KITE_API_KEY=
# KITE_API_SECRET=
