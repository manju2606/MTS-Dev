# ── Dev environment — copy to .env.dev and fill in values ────────────────────
# DB URLs are injected by docker-compose (they use docker service names).
# Only set app-level config here.

# Auth — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — allow the local Next.js dev server
CORS_ORIGINS=["http://localhost:3000"]

# App
ENVIRONMENT=development
DEBUG=true
PAPER_CAPITAL=100000.0

# AI (optional — rule-based engine used if not set)
# ANTHROPIC_API_KEY=sk-ant-...

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=your@gmail.com
# REPORT_TO_EMAIL=your@gmail.com
